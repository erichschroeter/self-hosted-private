BIND_IP=127.0.0.1
TRAEFIK_RULE=Host(`grimmory.localhost`)
TRAEFIK_ENTRYPOINT=web
TZ=America/Chicago

# App Config
APP_USER_ID=1000
APP_GROUP_ID=1000
DATABASE_URL=jdbc:mariadb://mariadb:3306/grimmory
DB_USER=grimmory
DB_PASSWORD=your_grimmory_db_password_here
API_DOCS_ENABLED=true
DISK_TYPE=local

# Database Config
DB_USER_ID=1000
DB_GROUP_ID=1000
MYSQL_ROOT_PASSWORD=your_mysql_root_password_here
MYSQL_DATABASE=grimmory
